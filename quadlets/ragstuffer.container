[Unit]
Description=ragstuffer — ingest documents into Qdrant from Drive/Git/Web
After=network-online.target

[Container]
# Locally built — tag with git SHA at build time:
#   podman build -t localhost/ragstuffer:$(git rev-parse --short HEAD) .
#   podman tag localhost/ragstuffer:$(git rev-parse --short HEAD) localhost/ragstuffer:main
Image=localhost/ragstuffer:main
ContainerName=ragstuffer

# Mount app code for dev workflow (matches Containerfile WORKDIR /app)
Volume=%h/git/ragstuffer:/app:ro,Z

# Service account key (read-only, not baked into image)
Volume=%h/.config/ramalama/gdrive-sa.json:/run/secrets/gdrive-sa.json:ro,Z

# Staging and repos directories for downloaded content
Volume=ragstuffer-staging:/tmp/rag-staging:Z
Volume=ragstuffer-repos:/tmp/rag-repos:Z

# State file persistence across restarts
Volume=%h/.local/share/ramalama:/state:Z

# Environment from shared config
EnvironmentFile=%h/.config/llm-stack/env

# Overrides — ragstuffer-specific
Environment=GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gdrive-sa.json
Environment=RAG_STATE_FILE=/state/rag-state.json
Environment=STAGING_DIR=/tmp/rag-staging

# Run as non-root. UserNS=keep-id maps host uid 1000 identically into the
# container so the bind-mounted SA key (0600, owned by host uid 1000) is
# readable. Without this, rootless Podman maps host uid 1000 to container
# root, and a User=1000 process sees the mount as an unmapped subuid and
# is denied by the 0600 mode. See issue #41.
User=1000
UserNS=keep-id:uid=1000,gid=1000

# Networking — needs access to Qdrant and ragpipe on the host
Network=host

# Health check — ragstuffer admin API
HealthCmd=curl -sf http://127.0.0.1:8091/health
HealthInterval=30s
HealthTimeout=10s
HealthRetries=3
HealthStartPeriod=60s

[Service]
Restart=on-failure
RestartSec=30

[Install]
WantedBy=default.target
